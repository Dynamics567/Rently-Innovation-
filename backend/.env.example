# ── App ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3001

# ── Database ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=rently
DB_PASSWORD=rently_dev_password
DB_NAME=rently
DB_SSL=false

# ── Redis ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Auth ─────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# ── Rate limiting ────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Third parties (populate per environment) ─────────
PAYSTACK_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=
SMS_PROVIDER_API_KEY=
